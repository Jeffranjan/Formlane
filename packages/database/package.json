    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "fast-check": "^3.23.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "^4.3.5"
  }
