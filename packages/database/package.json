    "dev": "dotenv -e ../../.env -- drizzle-kit studio",
    "seed": "dotenv -e ../../.env -- tsx seed.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
